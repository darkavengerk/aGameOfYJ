{
  "type": "standard_layout",
  "description": "표준 카드 레이아웃 (정책, 사건 카드 등)",
  "card": {
    "background": "#FFF8F0",
    "border_color": "#8B4513",
    "border_width": 3,
    "border_margin": 10
  },
  "elements": {
    "title": {
      "position": {"x": "center", "y": 30},
      "font": {"size": 24, "weight": "bold"},
      "color": "#2C1810"
    },
    "flavor_text": {
      "position": {"x": 20, "y": 80},
      "font": {"size": 12, "weight": "normal"},
      "color": "#654321",
      "max_width_ratio": 0.9
    },
    "effects": {
      "position": {"x": 20, "y": "auto"},
      "font": {"size": 13, "weight": "normal"},
      "color": "#2C1810",
      "line_height": 22
    },
    "trigger": {
      "position": {"x": 20, "y": 65},
      "font": {"size": 11, "weight": "normal"},
      "color": "#8B4513"
    },
    "special_ability": {
      "position": {"x": "center", "y": "bottom", "offset": 100},
      "box": {
        "height": 80,
        "background": "#F5F5DC",
        "border": {"color": "#8B4513", "width": 2},
        "margin": 20
      },
      "font": {"size": 12, "weight": "normal"},
      "color": "#2C1810"
    },
    "cost_badge": {
      "position": {"x": "right", "y": 20, "margin": 50},
      "font": {"size": 14, "weight": "bold"},
      "color": "#2C1810"
    }
  }
}
